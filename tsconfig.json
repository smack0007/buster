{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "typeRoots": [
      "./ext/@types",
    ],
    "types": ["node"],
    "strict": true,
    "paths": {
      "buster:ffi": ["./lib/ffi/index.ts"],
      "buster:jsonc": ["./lib/jsonc/index.ts"],
      "buster:test": ["./lib/test/index.ts"],
      "buster:webview": ["./lib/webview/index.ts"],
    }
  },
  "include": [
    "./examples/**/*.ts",
    "./lib/**/*.ts",
    "./src/**/*.ts",
    "./tests/**/*.ts"
  ],
}