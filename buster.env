# Static environment variables for buster
BUSTER_PATH="$(dirname $(realpath "${BASH_SOURCE[0]}"))"
BUSTER_BIN_PATH="${BUSTER_PATH}/bin"
BUSTER_EXT_PATH="${BUSTER_PATH}/ext"
BUSTER_NODE_PATH="${BUSTER_EXT_PATH}/node"
BUSTER_SRC_PATH="${BUSTER_PATH}/src"
BUSTER_TMP_PATH="${BUSTER_PATH}/tmp"

BUSTER_PLATFORM="$(echo "$(uname -s)-$(uname -m)" | tr '[:upper:]' '[:lower:]' | sed 's/x86_64/x64/')"

BUSTER_VERBOSE=${BUSTER_VERBOSE:-0}

BUSTER_VERSION="0.0.1"
BUSTER_NODE_OPTIONS="--strip-types"
BUSTER_NODE_VERSION=v25.8.2
