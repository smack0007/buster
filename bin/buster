#!/bin/bash
set -eu
source "$(dirname $(realpath "${BASH_SOURCE[0]}"))/../buster.env"

BUSTER_PATH="$(realpath $(dirname $(realpath "${BASH_SOURCE[0]}"))/..)"
BUSTER_BIN_PATH="${BUSTER_PATH}/bin"
BUSTER_EXT_PATH="${BUSTER_PATH}/ext"
BUSTER_SRC_PATH="${BUSTER_PATH}/src"
BUSTER_NODE_PATH="${BUSTER_EXT_PATH}/node"

BUSTER_NODE_OPTIONS="--strip-types --import ${BUSTER_SRC_PATH}/preload.ts"

BUSTER_VERBOSE=${BUSTER_VERBOSE:-0}

# Ensure everything is available via the PATH variable.
PATH="${BUSTER_BIN_PATH}:${BUSTER_NODE_PATH}/bin:${PATH}"

BUSTER_REPLACE_SIGNAL="$(mktemp)"

BUSTER_PATH="${BUSTER_PATH}" \
BUSTER_NODE_OPTIONS="${BUSTER_NODE_OPTIONS}" \
BUSTER_REPLACE_SIGNAL="${BUSTER_REPLACE_SIGNAL}" \
NODE_PATH="${BUSTER_EXT_PATH}" \
  ${BUSTER_NODE_PATH}/bin/node ${BUSTER_NODE_OPTIONS} "${BUSTER_SRC_PATH}/main.ts" ${@:-}

# If the file ${BUSTER_REPLACE_SIGNAL} has been written to, then the command
# written to that file should take over execution. 
if [ -f "${BUSTER_REPLACE_SIGNAL}" ]; then
  BUSTER_REPLACEMENT_PROCESS="$(cat "${BUSTER_REPLACE_SIGNAL}")"
  rm "${BUSTER_REPLACE_SIGNAL}"

BUSTER_PATH="${BUSTER_PATH}" \
NODE_PATH="${BUSTER_EXT_PATH}" \
  ${BUSTER_REPLACEMENT_PROCESS}
fi 